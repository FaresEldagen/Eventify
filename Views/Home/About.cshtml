@{
    ViewData["Title"] = "About Us";
}

<!-- Hero Section with Gradient Background -->
<section class="py-5 text-center text-white" style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); margin-top: -1px;">
    <div class="container py-5">
        <h1 class="display-4 fw-bold mb-3">About Eventify</h1>
        <p class="lead text-white-50 mx-auto" style="max-width: 700px;">
            Connecting people with the perfect venues and spectacular events. We make every occasion memorable and booking effortless.
        </p>
    </div>
</section>

<!-- Mission & Vision Section -->
<section class="py-5 bg-light">
    <div class="container py-4">
        <div class="row g-4 align-items-stretch">
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-4">
                    <div class="card-body">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-3 p-3 mb-4">
                            <i class="fas fa-bullseye fs-3 text-primary"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Our Mission</h3>
                        <p class="text-muted leading-relaxed">
                            At Eventify, our mission is to simplify event planning and venue booking. We bridge the gap between venue owners, event organizers, and attendees by providing a secure, seamless, and intuitive platform that brings spaces and experiences together.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-4">
                    <div class="card-body">
                        <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle text-success rounded-3 p-3 mb-4">
                            <i class="fas fa-eye fs-3 text-success"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Our Vision</h3>
                        <p class="text-muted leading-relaxed">
                            We envision a world where planning a celebration, corporate event, or community gathering is completely stress-free. Through cutting-edge technology and a user-focused design, Eventify aims to become the leading global event management platform.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Team Section -->
<section class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-dark">Meet Our Team</h2>
            <p class="lead text-muted">The passionate developers and designers who built Eventify</p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Fares Eldagen -->
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm text-center h-100 rounded-4 overflow-hidden team-card">
                    <div class="pt-4 px-4">
                        <div class="mx-auto rounded-circle overflow-hidden shadow-sm" style="width: 150px; height: 150px; border: 4px solid #fff;">
                            <img src="/images/Fares.jpg" alt="Fares Eldagen" class="w-100 h-100 object-fit-cover" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Fares+Eldagen&background=4f46e5&color=fff&size=150&font-size=0.33';">
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-1">Fares Eldagen</h4>
                        <a href="https://www.linkedin.com/in/fares-eldagen/" target="_blank" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                            <i class="fab fa-linkedin me-2"></i>LinkedIn
                        </a>
                    </div>
                </div>
            </div>

            <!-- Zyad Bash -->
