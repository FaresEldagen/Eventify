                    </div>
                </div>
            </div>

            <!-- Ahmed Albatrawy -->
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm text-center h-100 rounded-4 overflow-hidden team-card">
                    <div class="pt-4 px-4">
                        <div class="mx-auto rounded-circle overflow-hidden shadow-sm" style="width: 150px; height: 150px; border: 4px solid #fff;">
                            <img src="/images/Ahmed.jpg" alt="Ahmed Albatrawy" class="w-100 h-100 object-fit-cover" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Ahmed+Albatrawy&background=4f46e5&color=fff&size=150&font-size=0.33';">
