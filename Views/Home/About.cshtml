                            <i class="fab fa-linkedin me-2"></i>LinkedIn
                        </a>
                    </div>
                </div>
            </div>

            <!-- Amr Elsaeed -->
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm text-center h-100 rounded-4 overflow-hidden team-card">
                    <div class="pt-4 px-4">
                        <div class="mx-auto rounded-circle overflow-hidden shadow-sm" style="width: 150px; height: 150px; border: 4px solid #fff;">
                            <img src="/images/Amr.jpg" alt="Amr Elsaeed" class="w-100 h-100 object-fit-cover" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Amr+Elsaeed&background=4f46e5&color=fff&size=150&font-size=0.33';">
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-1">Amr Elsaeed</h4>
                        <a href="https://www.linkedin.com/in/amr-elsaeed-dev/" target="_blank" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                            <i class="fab fa-linkedin me-2"></i>LinkedIn
