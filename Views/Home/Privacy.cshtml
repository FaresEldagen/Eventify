@{
    ViewData["Title"] = "Privacy Policy";
}

<!-- Hero Section with Gradient Background -->
<section class="py-5 text-center text-white" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); margin-top: -1px;">
    <div class="container py-4">
        <h1 class="display-4 fw-bold mb-3">Privacy Policy</h1>
        <p class="lead text-white-50 mx-auto" style="max-width: 700px;">
            Your privacy is extremely important to us. Here is how we handle and protect your personal data.
        </p>
    </div>
</section>

<!-- Content Section -->
<section class="py-5 bg-light">
    <div class="container py-3">
        <div class="row">
            <div class="col-lg-10 mx-auto">
                <div class="card border-0 shadow-sm p-4 p-md-5 rounded-4 bg-white">
                    <div class="card-body">
                        <p class="text-muted small mb-4">Last updated: July 6, 2026</p>

                        <div class="mb-5">
                            <h3 class="fw-bold text-dark mb-3"><i class="fas fa-database text-primary me-2"></i>1. Information We Collect</h3>
                            <p class="text-muted">
                                When you use Eventify, we collect information to provide better services to our users. This includes:
                            </p>
                            <ul class="text-muted">
                                <li><strong>Account Profile Information:</strong> Your name, email address, password, profile picture, and contact information.</li>
                                <li><strong>Listing Data:</strong> Venue descriptions, event details, photos, capacity, pricing, and availability.</li>
                                <li><strong>Transaction Information:</strong> Ticket bookings, reservation details, payments, and payout settings.</li>
                            </ul>
                        </div>

                        <div class="mb-5">
                            <h3 class="fw-bold text-dark mb-3"><i class="fas fa-cogs text-primary me-2"></i>2. How We Use Your Information</h3>
                            <p class="text-muted">
                                The data we collect is utilized to operate, maintain, and improve the Eventify platform. This includes using it to:
                            </p>
                            <ul class="text-muted">
                                <li>Facilitate venue listings, bookings, and ticket reservations.</li>
                                <li>Process payments, security checks, and payout transactions.</li>
                                <li>Provide customer support and send notification alerts regarding bookings.</li>
                                <li>Analyze platform usage to optimize the interface and performance.</li>
                            </ul>
                        </div>

                        <div class="mb-5">
                            <h3 class="fw-bold text-dark mb-3"><i class="fas fa-share-alt text-primary me-2"></i>3. Sharing Your Information</h3>
                            <p class="text-muted">
                                We do not sell your personal data. Your information is shared only under specific circumstances:
                            </p>
                            <ul class="text-muted">
                                <li><strong>With Other Users:</strong> Booking info is shared between host and guest to complete reservations.</li>
                                <li><strong>Service Providers:</strong> We share necessary details with payment processing and notification services.</li>
                                <li><strong>Legal Requirements:</strong> If required to do so by applicable Egyptian laws.</li>
                            </ul>
                        </div>

                        <div class="mb-5">
                            <h3 class="fw-bold text-dark mb-3"><i class="fas fa-lock text-primary me-2"></i>4. Data Security</h3>
                            <p class="text-muted">
                                We implement standard industry security measures, including HTTPS encryption, password hashing, and secure payment pathways, to protect your personal information from unauthorized access, loss, or alteration.
                            </p>
                        </div>

                        <div class="mb-5">
                            <h3 class="fw-bold text-dark mb-3"><i class="fas fa-user-shield text-primary me-2"></i>5. Your Choices &amp; Control</h3>
                            <p class="text-muted">
                                You can access, edit, or delete your account information at any time through your Profile Dashboard. If you wish to permanently delete your account, please send us a request via the email address listed below.
                            </p>
                        </div>

                        <div class="mb-4">
                            <h3 class="fw-bold text-dark mb-3"><i class="fas fa-envelope-open-text text-primary me-2"></i>6. Contact Us</h3>
                            <p class="text-muted">
                                If you have questions or concerns about this Privacy Policy or our practices, please contact us:
                            </p>
                            <address class="text-muted border-start border-3 border-primary ps-3 py-1">
                                <strong>Eventify Privacy Office</strong><br>
                                Damietta, Egypt<br>
                                Email: hello@eventify.com<br>
                                Phone: +20 101 234 5678
                            </address>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
